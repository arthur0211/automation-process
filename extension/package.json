{
  "name": "agentic-automation-extension",
  "version": "1.0.0",
  "description": "Chrome Extension that records and documents web processes for humans and LLMs",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dexie": "^4.3.0",
    "preact": "^10.28.4",
    "wxt": "^0.20.17",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/vite": "^4.2.0",
    "@types/chrome": "^0.1.37",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.7.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
